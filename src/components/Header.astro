---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Αρχική', href: '/' },
  { label: 'Το Χωριό', href: '/village/' },
  { label: 'Νέα', href: '/news/' },
  { label: 'Γκαλερί', href: '/gallery/' },
  { label: 'Σύλλογος', href: '/association/' },
  { label: 'Εκδηλώσεις', href: '/events/' },
  { label: 'Απόδημοι', href: '/diaspora/' },
  { label: 'Επικοινωνία', href: '/contact/' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="absolute inset-0 bg-parchment/90 backdrop-blur-md border-b border-stone-warm/30 opacity-0 transition-opacity duration-500" id="header-bg"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-full bg-olive flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
          <span class="text-white font-display font-bold text-lg">B</span>
        </div>
        <div class="flex flex-col">
          <span class="font-display font-bold text-lg leading-tight text-charcoal" id="logo-text">Βαρλαάμ</span>
          <span class="font-accent text-xs text-stone-dark italic tracking-wider" id="logo-sub">Ιωαννίνων</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 font-body text-sm font-medium tracking-wide rounded-sm transition-all duration-300',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-terracotta'
                : 'text-charcoal/70 hover:text-charcoal hover:bg-stone-warm/20',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-1.5 p-2 group"
        aria-label="Μενού"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-charcoal transition-all duration-300 origin-center group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
        <span class="block w-6 h-0.5 bg-charcoal transition-all duration-300 group-[.open]:opacity-0"></span>
        <span class="block w-6 h-0.5 bg-charcoal transition-all duration-300 origin-center group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-20 bg-parchment/98 backdrop-blur-xl -translate-x-full transition-transform duration-500 ease-out">
    <nav class="flex flex-col items-center justify-center h-full gap-2 -mt-20">
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            'font-display text-2xl py-3 px-6 rounded-sm transition-all duration-300',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-terracotta'
              : 'text-charcoal/70 hover:text-charcoal hover:bg-stone-warm/20',
          ]}
          style={`animation-delay: ${i * 0.05}s`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Header background on scroll
  const header = document.getElementById('site-header');
  const headerBg = document.getElementById('header-bg');

  function updateHeader() {
    if (window.scrollY > 50) {
      headerBg?.classList.replace('opacity-0', 'opacity-100');
    } else {
      headerBg?.classList.replace('opacity-100', 'opacity-0');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    if (isOpen) {
      mobileMenu?.classList.replace('-translate-x-full', 'translate-x-0');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.replace('translate-x-0', '-translate-x-full');
      document.body.style.overflow = '';
    }
  });
</script>
