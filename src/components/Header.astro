---
import LangToggle from './LangToggle.astro';
import Logomark from './Logomark.astro';
const currentPath = Astro.url.pathname;

const navItems = [
  { el: 'Αρχική', en: 'Home', href: '/' },
  { el: 'Το Χωριό', en: 'The Village', href: '/village/' },
  { el: 'Αξιοθέατα', en: 'Attractions', href: '/attractions/' },
  { el: 'Φωτογραφίες', en: 'Photos', href: '/gallery/' },
  { el: 'Ανακοινώσεις', en: 'News', href: '/news/' },
  { el: 'Εκδηλώσεις', en: 'Events', href: '/events/' },
  { el: 'Αναμνήσεις', en: 'Memories', href: '/anamniseis/' },
  { el: 'Σύλλογος', en: 'Association', href: '/association/' },
  { el: 'Απόδημοι', en: 'Diaspora', href: '/diaspora/' },
  { el: 'Επικοινωνία', en: 'Contact', href: '/contact/' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" data-scrolled="false">
  <div class="absolute inset-0 bg-parchment/90 backdrop-blur-md border-b border-stone-warm/30 opacity-0 transition-opacity duration-300" id="header-bg"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div id="header-inner" class="flex items-center justify-between h-20 transition-[height] duration-300 ease-out">
      <a href="/" class="flex items-center gap-3 group">
        <div id="header-logo" class="w-10 h-10 flex items-center justify-center transition-all duration-300 group-hover:scale-110">
          <Logomark size={40} />
        </div>
        <div class="flex flex-col">
          <span class="header-wordmark font-display font-bold text-lg leading-tight tracking-tight transition-colors duration-300">
            <span data-lang="el">Βαρλαάμ</span>
            <span data-lang="en">Varlaam</span>
          </span>
          <span id="header-tagline" class="header-tagline font-accent text-xs italic tracking-wider overflow-hidden transition-[max-height,opacity,color] duration-300" style="max-height:1rem;">
            <span data-lang="el">Ιωαννίνων</span>
            <span data-lang="en">Ioannina</span>
          </span>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              data-nav-link
              class:list={[
                'header-nav-link px-3 py-2 font-body text-sm font-medium tracking-wide rounded-sm transition-all duration-300',
                isActive ? 'is-active' : '',
              ]}
            >
              <span data-lang="el">{item.el}</span>
              <span data-lang="en">{item.en}</span>
            </a>
          );
        })}
        <div class="ml-2 pl-2 border-l border-current/20 opacity-70">
          <LangToggle />
        </div>
      </nav>

      <div class="lg:hidden flex items-center gap-2">
        <LangToggle />
        <button
          id="mobile-menu-btn"
          class="flex flex-col gap-1.5 p-2 group"
          aria-label="Μενού"
          aria-expanded="false"
        >
          <span class="mobile-bar block w-6 h-0.5 transition-all duration-300 origin-center group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
          <span class="mobile-bar block w-6 h-0.5 transition-all duration-300 group-[.open]:opacity-0"></span>
          <span class="mobile-bar block w-6 h-0.5 transition-all duration-300 origin-center group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></span>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-20 bg-parchment/98 backdrop-blur-xl -translate-x-full transition-transform duration-500 ease-out">
    <nav class="flex flex-col items-center justify-center h-full gap-2 -mt-20">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'font-display text-2xl py-3 px-6 rounded-sm transition-all duration-300',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-terracotta'
              : 'text-charcoal/70 hover:text-charcoal hover:bg-stone-warm/20',
          ]}
        >
          <span data-lang="el">{item.el}</span>
          <span data-lang="en">{item.en}</span>
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const headerBg = document.getElementById('header-bg');
  const headerInner = document.getElementById('header-inner');
  const headerLogo = document.getElementById('header-logo');
  const headerTagline = document.getElementById('header-tagline');
  const siteHeader = document.getElementById('site-header');
  function updateHeader() {
    const scrolled = window.scrollY > 50;
    siteHeader?.setAttribute('data-scrolled', scrolled ? 'true' : 'false');
    if (scrolled) {
      headerBg?.classList.replace('opacity-0', 'opacity-100');
      headerInner?.classList.replace('h-20', 'h-14');
      headerLogo?.classList.remove('w-10', 'h-10');
      headerLogo?.classList.add('w-8', 'h-8');
      if (headerTagline) {
        headerTagline.style.maxHeight = '0';
        headerTagline.style.opacity = '0';
      }
    } else {
      headerBg?.classList.replace('opacity-100', 'opacity-0');
      headerInner?.classList.replace('h-14', 'h-20');
      headerLogo?.classList.add('w-10', 'h-10');
      headerLogo?.classList.remove('w-8', 'h-8');
      if (headerTagline) {
        headerTagline.style.maxHeight = '1rem';
        headerTagline.style.opacity = '1';
      }
    }
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    if (isOpen) {
      mobileMenu?.classList.replace('-translate-x-full', 'translate-x-0');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.replace('translate-x-0', '-translate-x-full');
      document.body.style.overflow = '';
    }
  });
</script>
