---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-white/80 relative overflow-hidden">
  <!-- Decorative top border -->
  <div class="h-1 bg-gold-accent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- About -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-olive flex items-center justify-center">
            <span class="text-white font-display font-bold text-lg">B</span>
          </div>
          <div>
            <h3 class="font-display font-bold text-xl text-white">Βαρλαάμ</h3>
            <p class="font-accent text-xs text-gold-warm italic">Ιωαννίνων</p>
          </div>
        </div>
        <p class="font-body text-sm leading-relaxed text-white/60">
          Η επίσημη ιστοσελίδα του χωριού Βαρλαάμ Ιωαννίνων.
          Ένας τόπος γεμάτος ιστορία, παράδοση και φυσική ομορφιά.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display font-semibold text-lg text-white mb-6">Σελίδες</h3>
        <ul class="space-y-3">
          <li><a href="/village/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Το Χωριό μας</a></li>
          <li><a href="/news/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Νέα & Ανακοινώσεις</a></li>
          <li><a href="/gallery/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Γκαλερί</a></li>
          <li><a href="/events/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Εκδηλώσεις</a></li>
          <li><a href="/diaspora/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Απόδημοι</a></li>
          <li><a href="/contact/" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">Επικοινωνία</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-semibold text-lg text-white mb-6">Επικοινωνία</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-terracotta mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="font-body text-sm text-white/60">Βαρλαάμ, Ιωάννινα<br/>Ήπειρος, Ελλάδα</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-terracotta shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:info@varlaam.gr" class="font-body text-sm text-white/60 hover:text-gold-warm transition-colors duration-300">info@varlaam.gr</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-white/40">
        &copy; {year} Σύλλογος Βαρλαάμ Ιωαννίνων. Με επιφύλαξη παντός δικαιώματος.
      </p>
      <p class="font-accent text-xs text-white/30 italic">
        Με αγάπη για το χωριό μας
      </p>
    </div>
  </div>
</footer>
