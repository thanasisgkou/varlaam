---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description = 'Η επίσημη ιστοσελίδα του χωριού Βαρλαάμ Ιωαννίνων - Ήπειρος, Ελλάδα. Να μη συγχέεται με τη Μονή Βαρλαάμ Μετεώρων.', image, jsonLd } = Astro.props;
const fullTitle = title === 'Αρχική' ? 'Βαρλαάμ Ιωαννίνων — Χωριό στην Ήπειρο' : `${title} | Βαρλαάμ Ιωαννίνων — Χωριό Ηπείρου`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? '/images/hero/varlaam-01.jpg', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Βαρλαάμ Ιωαννίνων, χωριό Βαρλαάμ, Βαρλαάμ Ηπείρου, Ήπειρος, Ιωάννινα, σύλλογος Βαρλαάμ" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="el_GR" />
  <meta property="og:locale:alternate" content="en_GB" />
  <meta property="og:site_name" content="Βαρλαάμ Ιωαννίνων" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Βαρλαάμ Ιωαννίνων — θέα από το Ξηροβούνι" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content="Βαρλαάμ Ιωαννίνων — θέα από το Ξηροβούνι" />
  <meta name="theme-color" content="#7a2e1f" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Βαρλαάμ Ιωαννίνων — Ανακοινώσεις" href="/rss.xml" />
  <title>{fullTitle}</title>

  <!-- Structured Data: Local Organization - NOT the Meteora monastery -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CivicStructure",
    "name": "Βαρλαάμ Ιωαννίνων",
    "alternateName": ["Varlaam Ioannina", "Βαρλαάμ Ηπείρου", "Χωριό Βαρλαάμ"],
    "description": "Το χωριό Βαρλαάμ στον νομό Ιωαννίνων, Ήπειρος, Ελλάδα. Να μη συγχέεται με τη Μονή Βαρλαάμ Μετεώρων.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Βαρλαάμ",
      "addressRegion": "Ιωάννινα",
      "postalCode": "455 00",
      "addressCountry": "GR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 39.4207967,
      "longitude": 20.8934205
    },
    "url": "https://varlaam.netlify.app",
    "sameAs": []
  })} />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <!-- Netlify Identity widget — picks up #invite_token / #confirmation_token /
       #recovery_token landing on the public site and routes the user to /admin/
       after they finish onboarding. Loads once globally. -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
</head>
<body class="min-h-screen flex flex-col">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:rounded-md focus:bg-charcoal focus:text-parchment focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-gold-warm"
  >
    <span data-lang="el">Μετάβαση στο κύριο περιεχόμενο</span>
    <span data-lang="en">Skip to main content</span>
  </a>
  <div class="noise-overlay" aria-hidden="true"></div>
  <Header />
  <main id="main-content" tabindex="-1" class="flex-1">
    <slot />
  </main>
  <Footer />
  <BackToTop />
  <GlossaryTooltips />

  <script is:inline>
    // After completing invite / confirmation / recovery (URL fragment
    // contains a token), Netlify Identity opens its modal automatically.
    // Once the user finishes, send them to /admin/ instead of leaving
    // them on the marketing homepage.
    (function () {
      if (!window.netlifyIdentity) return;
      window.netlifyIdentity.on('init', function (user) {
        if (!user) {
          window.netlifyIdentity.on('login', function () {
            document.location.href = '/admin/';
          });
        }
      });
    })();
  </script>

  <script>
    // Scroll animation observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.animate-on-scroll').forEach((el) => {
      observer.observe(el);
    });
  </script>
</body>
</html>
