---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Σελίδα δεν βρέθηκε" description="Η σελίδα που ζητήσατε δεν βρέθηκε">

  <section class="min-h-[70vh] flex items-center justify-center bg-parchment relative overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-1/4 left-1/4 w-64 h-64 rounded-full border-2 border-terracotta"></div>
      <div class="absolute bottom-1/4 right-1/4 w-48 h-48 rounded-full border border-olive"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full border border-stone-warm"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">
      <!-- Large 404 -->
      <div class="mb-8">
        <span class="font-display text-[10rem] md:text-[14rem] font-bold leading-none text-gradient opacity-40">
          404
        </span>
      </div>

      <!-- Mountain illustration -->
      <svg class="w-32 h-20 mx-auto text-stone-warm/30 mb-8" viewBox="0 0 120 60" fill="currentColor">
        <path d="M0 60 L30 15 L45 35 L60 10 L75 30 L90 20 L120 60 Z" opacity="0.3"/>
        <path d="M10 60 L40 25 L55 40 L70 20 L85 35 L110 60 Z" opacity="0.5"/>
      </svg>

      <h1 class="font-display text-3xl md:text-4xl font-bold text-charcoal mb-4">
        Χαθήκατε στο βουνό;
      </h1>
      <p class="font-body text-lg text-charcoal/60 mb-10 leading-relaxed">
        Η σελίδα που ψάχνετε δεν βρέθηκε. Ίσως μετακινήθηκε ή δεν υπάρχει πια.
        Ας σας οδηγήσουμε πίσω στο χωριό!
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Πίσω στην Αρχική
        </a>
        <a href="/contact" class="btn-secondary">
          Επικοινωνία
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
