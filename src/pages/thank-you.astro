---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ευχαριστούμε"
  description="Η υποβολή σας στάλθηκε με επιτυχία στον Σύλλογο Βαρλαάμ Ιωαννίνων."
>

  <section class="min-h-[70vh] flex items-center justify-center bg-parchment relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-1/4 left-1/4 w-64 h-64 rounded-full border-2 border-olive"></div>
      <div class="absolute bottom-1/4 right-1/4 w-48 h-48 rounded-full border border-terracotta"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-xl mx-auto">
      <div class="w-20 h-20 mx-auto mb-8 rounded-full bg-olive/10 flex items-center justify-center">
        <svg class="w-10 h-10 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <div class="flex items-center justify-center mb-4">
        <span class="block w-12 h-px bg-terracotta/50"></span>
        <span class="mx-4 text-terracotta text-xs font-accent tracking-[0.3em] uppercase">
          <span data-lang="el">Ευχαριστούμε</span>
          <span data-lang="en">Thank you</span>
        </span>
        <span class="block w-12 h-px bg-terracotta/50"></span>
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-bold text-charcoal mb-5">
        <span data-lang="el">Η υποβολή σας στάλθηκε</span>
        <span data-lang="en">Your submission was received</span>
      </h1>

      <p class="font-body text-lg text-charcoal/75 mb-10 leading-relaxed">
        <span data-lang="el">Ο Σύλλογος θα ελέγξει την υποβολή σας και θα επικοινωνήσει μαζί σας στο email που δώσατε (αν δώσατε κάποιο). Ευχαριστούμε που στηρίζετε το χωριό.</span>
        <span data-lang="en">The Association will review your submission and get in touch via the email you provided (if any). Thank you for supporting the village.</span>
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          <span data-lang="el">← Αρχική</span>
          <span data-lang="en">← Home</span>
        </a>
        <a href="/diaspora/" class="btn-secondary">
          <span data-lang="el">Απόδημοι</span>
          <span data-lang="en">Diaspora</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
