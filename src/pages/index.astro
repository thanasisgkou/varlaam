---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Αρχική" description="Η επίσημη ιστοσελίδα του χωριού Βαρλαάμ Ιωαννίνων - Ένας τόπος γεμάτος ιστορία και ζωή στην καρδιά της Ηπείρου">

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Gradient/Pattern Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-stone-dark to-olive-dark"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 25%, rgba(193,154,107,0.3) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(107,142,35,0.2) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(183,65,14,0.15) 0%, transparent 50%);"></div>
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23c19a6b&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); opacity: 0.3;"></div>

    <!-- Decorative Elements -->
    <div class="absolute top-20 left-10 w-32 h-32 border border-gold-warm/20 rounded-full animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-48 h-48 border border-gold-warm/10 rounded-full"></div>
    <div class="absolute top-1/4 right-1/4 w-2 h-2 bg-gold-warm/40 rounded-full"></div>
    <div class="absolute bottom-1/3 left-1/3 w-3 h-3 bg-gold-warm/30 rounded-full"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <!-- Ornamental Line -->
      <div class="flex items-center justify-center mb-8 animate-fade-in">
        <span class="block w-12 h-px bg-gold-warm/60"></span>
        <span class="mx-4 text-gold-warm/80 text-sm font-accent tracking-[0.3em] uppercase">Ήπειρος</span>
        <span class="block w-12 h-px bg-gold-warm/60"></span>
      </div>

      <h1 class="font-display text-7xl md:text-8xl lg:text-9xl font-bold text-white mb-4 animate-fade-up" style="text-shadow: 0 4px 30px rgba(0,0,0,0.3);">
        <span class="text-gradient">Βαρλαάμ</span>
      </h1>

      <p class="font-accent text-2xl md:text-3xl text-gold-light tracking-wide mb-6 animate-fade-up" style="animation-delay: 0.2s;">
        Ιωαννίνων &middot; Ήπειρος
      </p>

      <div class="w-16 h-px bg-gradient-to-r from-transparent via-gold-warm to-transparent mx-auto mb-8 animate-fade-in" style="animation-delay: 0.4s;"></div>

      <p class="font-body text-xl md:text-2xl text-stone-warm/90 max-w-2xl mx-auto mb-12 animate-fade-up" style="animation-delay: 0.4s;">
        Ένας τόπος γεμάτος ιστορία και ζωή
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up" style="animation-delay: 0.6s;">
        <a href="/attractions" class="btn-primary text-lg px-8 py-4">
          <span data-lang="el">Ανακαλύψτε το χωριό</span>
          <span data-lang="en">Discover the village</span>
        </a>
        <a href="/gallery" class="btn-secondary-light text-lg px-8 py-4">
          <span data-lang="el">Φωτογραφίες</span>
          <span data-lang="en">Photos</span>
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-10 text-gold-warm/50" fill="none" stroke="currentColor" viewBox="0 0 24 40">
        <rect x="1" y="1" width="22" height="38" rx="11" stroke-width="2"/>
        <circle cx="12" cy="12" r="3" fill="currentColor">
          <animate attributeName="cy" values="12;24;12" dur="2s" repeatCount="indefinite"/>
        </circle>
      </svg>
    </div>
  </section>

  <!-- Welcome Section -->
  <section class="py-24 bg-parchment">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="animate-on-scroll text-center">
        <!-- Ornamental Element -->
        <div class="flex items-center justify-center mb-6">
          <span class="block w-8 h-px bg-terracotta/40"></span>
          <svg class="w-6 h-6 mx-3 text-terracotta/60" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2Z"/>
          </svg>
          <span class="block w-8 h-px bg-terracotta/40"></span>
        </div>

        <h2 class="section-title">
          <span data-lang="el">Καλώς ήρθατε</span>
          <span data-lang="en">Welcome</span>
        </h2>
        <p class="section-subtitle mb-8">
          <span data-lang="el">στο Βαρλαάμ Ιωαννίνων</span>
          <span data-lang="en">to Varlaam, Ioannina</span>
        </p>

        <div class="divider mx-auto mb-12"></div>

        <div data-lang="el" class="space-y-6 text-left font-body text-lg text-charcoal/80 leading-relaxed">
          <p>Το Βαρλαάμ βρίσκεται στις ανατολικές πλαγιές του όρους Ξηροβούνι, ανατολικά του ποταμού Λούρου, και απέχει 32,5 χιλιόμετρα νότια από την πόλη των Ιωαννίνων.</p>
          <p>Ο Γάλλος περιηγητής Φρανσουά Πουκεβίλ αναφέρει ότι το 1813, την περίοδο της τουρκοκρατίας, κατοικείτο από 60 ελληνικές οικογένειες. Στα οθωμανικά κατάστιχα του 1895 το χωριό αναφέρεται με το όνομα <em>Βαρλάμι</em>, ως τσιφλίκι του καζά Ιωαννίνων με 200 κατοίκους.</p>
          <p>Ως οικισμός συστάθηκε το 1919 με το ΦΕΚ 184Α - 19/08/1919 και ορίστηκε έδρα της ομώνυμης κοινότητας. Σύμφωνα με το σχέδιο Καλλικράτης — και την τροποποίησή του Κλεισθένης Ι — αποτελεί την κοινότητα Βαρλαάμ που ανήκει στη δημοτική ενότητα Αγίου Δημητρίου του Δήμου Δωδώνης. Σύμφωνα με την απογραφή 2011, ο πληθυσμός του ανέρχεται σε 112 κατοίκους.</p>
        </div>

        <div data-lang="en" class="space-y-6 text-left font-body text-lg text-charcoal/80 leading-relaxed">
          <p>Varlaam is located on the eastern slopes of Mount Xirovouni, east of the Louros River, 32.5 kilometers south of the city of Ioannina.</p>
          <p>The French traveler François Pouqueville reports that in 1813, during the period of Ottoman rule, it was inhabited by 60 Greek families. In the Ottoman records of 1895, the village is mentioned under the name <em>Varlami</em>, as a manor of the Ioannina kaza with 200 residents.</p>
          <p>It was established as a settlement in 1919 with Government Gazette 184A - 19/08/1919 and was designated the seat of the homonymous community. According to the Kallikratis plan — and its Cleisthenes I modification — it constitutes the community of Varlaam, belonging to the municipal unit of Agios Dimitrios of the Municipality of Dodoni. According to the 2011 census, it has a population of 112 residents.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Drone Video Section -->
  <section class="py-20 bg-charcoal">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="animate-on-scroll text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3">
          <span data-lang="el">Το Βαρλαάμ από ψηλά</span>
          <span data-lang="en">Varlaam from above</span>
        </h2>
        <div class="w-16 h-px bg-gradient-to-r from-transparent via-gold-warm to-transparent mx-auto"></div>
      </div>
      <div class="animate-on-scroll relative w-full rounded-sm overflow-hidden shadow-2xl" style="aspect-ratio: 16 / 9;">
        <iframe
          class="absolute inset-0 w-full h-full"
          src="https://www.youtube-nocookie.com/embed/0zj4Gfb29zM"
          title="Βαρλαάμ Ιωαννίνων — Drone video"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="animate-on-scroll text-center mb-16">
        <h2 class="section-title">
          <span data-lang="el">Ανακοινώσεις</span>
          <span data-lang="en">Announcements</span>
        </h2>
        <p class="section-subtitle">
          <span data-lang="el">Ενημερωθείτε για τα τελευταία νέα του χωριού μας</span>
          <span data-lang="en">Stay up to date with the latest from the village</span>
        </p>
        <div class="divider mx-auto mt-6"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestNews.map((post, index) => (
          <article class="animate-on-scroll card group" style={`animation-delay: ${index * 0.15}s;`}>
            <!-- Image -->
            <div class="relative h-48 overflow-hidden bg-gradient-to-br from-stone-warm/30 to-olive/20">
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="flex items-center justify-center h-full">
                  <svg class="w-12 h-12 text-stone-warm/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </div>
              )}
              <div class="absolute inset-0 bg-olive-dark/0 group-hover:bg-olive-dark/10 transition-colors duration-300"></div>
            </div>

            <div class="p-6">
              <time class="text-sm text-terracotta font-accent" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('el-GR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="font-display text-xl text-charcoal mt-2 mb-3 group-hover:text-olive-dark transition-colors">
                <a href={`/news/${post.slug}`} class="hover:underline decoration-terracotta/30 underline-offset-4">
                  {post.data.title}
                </a>
              </h3>
              <p class="font-body text-charcoal/70 text-sm leading-relaxed line-clamp-3">
                {post.data.excerpt}
              </p>
            </div>
          </article>
        ))}
      </div>

      {latestNews.length === 0 && (
        <div class="text-center py-12">
          <p class="font-body text-charcoal/60 text-lg">Δεν υπάρχουν νέα ακόμα. Μείνετε συντονισμένοι!</p>
        </div>
      )}

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/news" class="btn-secondary">
          <span data-lang="el">Όλες οι ανακοινώσεις →</span>
          <span data-lang="en">All announcements →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Village Stats Section -->
  <section class="py-24 bg-gradient-to-br from-olive-dark to-charcoal relative overflow-hidden">
    <!-- Decorative Pattern -->
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M20 20.5V18H0v-2h20v-2l2 3-2 3zm0-10V8H0V6h20V4l2 3-2 3z&quot; fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot; fill-rule=&quot;evenodd&quot;/%3E%3C/svg%3E');"></div>

    <div class="container mx-auto px-4 max-w-6xl relative z-10">
      <div class="animate-on-scroll text-center mb-16">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">Το Βαρλαάμ σε αριθμούς</h2>
        <div class="w-16 h-px bg-gradient-to-r from-transparent via-gold-warm to-transparent mx-auto"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        <div class="animate-on-scroll text-center" style="animation-delay: 0.1s;">
          <div class="font-display text-5xl md:text-6xl font-bold text-gold-warm mb-2">500+</div>
          <div class="font-accent text-lg text-stone-warm/80 tracking-wide">Χρόνια Ιστορίας</div>
        </div>
        <div class="animate-on-scroll text-center" style="animation-delay: 0.2s;">
          <div class="font-display text-5xl md:text-6xl font-bold text-gold-warm mb-2">850</div>
          <div class="font-accent text-lg text-stone-warm/80 tracking-wide">Μέτρα Υψόμετρο</div>
        </div>
        <div class="animate-on-scroll text-center" style="animation-delay: 0.3s;">
          <div class="font-display text-5xl md:text-6xl font-bold text-gold-warm mb-2">1</div>
          <div class="font-accent text-lg text-stone-warm/80 tracking-wide">Ιστορική Εκκλησία</div>
        </div>
        <div class="animate-on-scroll text-center" style="animation-delay: 0.4s;">
          <div class="font-display text-5xl md:text-6xl font-bold text-gold-warm mb-2">&infin;</div>
          <div class="font-accent text-lg text-stone-warm/80 tracking-wide">Αναμνήσεις</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Diaspora CTA Section -->
  <section class="py-24 bg-parchment relative">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="animate-on-scroll text-center">
        <!-- Ornamental Frame -->
        <div class="relative border-2 border-terracotta/20 rounded-lg p-12 md:p-16">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-parchment px-6">
            <svg class="w-6 h-6 text-terracotta/60 inline-block" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>

          <h2 class="font-display text-3xl md:text-4xl font-bold text-charcoal mb-4">
            <span data-lang="el">Είστε Απόδημος Βαρλαάμ;</span>
            <span data-lang="en">Are you from the Varlaam diaspora?</span>
          </h2>
          <p class="font-body text-lg text-charcoal/70 mb-8 max-w-2xl mx-auto leading-relaxed">
            <span data-lang="el">Όπου κι αν βρίσκεστε στον κόσμο, το Βαρλαάμ θα είναι πάντα το σπίτι σας. Μείνετε συνδεδεμένοι με τις ρίζες σας, μοιραστείτε τις ιστορίες σας και συμβάλετε στο μέλλον του χωριού μας.</span>
            <span data-lang="en">Wherever in the world you are, Varlaam will always be home. Stay connected to your roots, share your stories, and help shape the village's future.</span>
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/diaspora" class="btn-primary">
              <span data-lang="el">Κοινότητα Αποδήμων</span>
              <span data-lang="en">Diaspora Community</span>
            </a>
            <a href="/contact" class="btn-secondary">
              <span data-lang="el">Επικοινωνήστε μαζί μας</span>
              <span data-lang="en">Get in touch</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
