---
import BaseLayout from '../layouts/BaseLayout.astro';

type EventAlbum = {
  slug: string;
  year: number;
  theme: 'feast' | 'celebration' | 'village' | 'other';
  title: string;
  titleEn: string;
  description: string;
  descriptionEn: string;
  folder: string;
  prefix: string;
  count: number;
};

const events: EventAlbum[] = [
  {
    slug: 'kopi-pitas-athina-2026',
    year: 2026,
    theme: 'celebration',
    title: 'Κοπή Πίτας — Αθήνα',
    titleEn: 'Cutting of the New Year Cake — Athens',
    description: 'Η ετήσια κοπή της πρωτοχρονιάτικης πίτας του Συλλόγου για τους αποδήμους στην Αθήνα — μια συνάντηση αγάπης και αναμνήσεων.',
    descriptionEn: 'The annual New Year cake-cutting event organised by the Association in Athens for the diaspora — a gathering of warmth and memories.',
    folder: '/images/events/2026/kopi-pitas-athina',
    prefix: 'kpa',
    count: 12,
  },
  {
    slug: 'kopi-pitas-varlaam-2026',
    year: 2026,
    theme: 'celebration',
    title: 'Κοπή Πίτας — Βαρλαάμ',
    titleEn: 'Cutting of the New Year Cake — Varlaam',
    description: 'Η κοπή της πίτας στο ίδιο το χωριό, με τους κατοίκους και όσους επέλεξαν να γιορτάσουν στον τόπο τους.',
    descriptionEn: 'The cake-cutting celebration held in the village itself, bringing together residents and visitors.',
    folder: '/images/events/2026/kopi-pitas-varlaam',
    prefix: 'kpv',
    count: 6,
  },
  {
    slug: 'mpirmpilato-2026',
    year: 2026,
    theme: 'feast',
    title: 'Μπιρμπιλάτο',
    titleEn: 'Mpirmpilato Feast',
    description: 'Παραδοσιακή εκδήλωση του χωριού, μια παλιά τοπική συνήθεια που αναβιώνει κάθε χρόνο με φαγητό, μουσική και χορό.',
    descriptionEn: 'A traditional village gathering — a cherished local custom revived each year with food, music and dance.',
    folder: '/images/events/2026/mpirmpilato',
    prefix: 'mpirmpilato',
    count: 8,
  },
  {
    slug: 'pasxa-2026',
    year: 2026,
    theme: 'feast',
    title: 'Πάσχα στο Βαρλαάμ',
    titleEn: 'Easter in Varlaam',
    description: 'Οι εορτασμοί του Πάσχα στο χωριό — η ατμόσφαιρα της Μεγάλης Εβδομάδας, η Ανάσταση και το παραδοσιακό γλέντι.',
    descriptionEn: 'Easter celebrations in the village — the atmosphere of Holy Week, the Resurrection and the traditional feast.',
    folder: '/images/events/2026/pasxa',
    prefix: 'pasxa',
    count: 4,
  },
];

const years = [...new Set(events.map((e) => e.year))].sort((a, b) => b - a);
const themes = [
  { id: 'all', el: 'Όλες οι κατηγορίες', en: 'All themes' },
  { id: 'feast', el: 'Πανηγύρια & Γιορτές', en: 'Feasts & Festivals' },
  { id: 'celebration', el: 'Εκδηλώσεις Συλλόγου', en: 'Association events' },
  { id: 'village', el: 'Το Χωριό', en: 'The Village' },
];
---

<BaseLayout title="Φωτογραφίες" description="Φωτογραφικό αρχείο του χωριού Βαρλαάμ — εκδηλώσεις χωρισμένες θεματολογικά και χρονολογικά">

  <section class="relative py-28 md:py-36 bg-gradient-to-br from-charcoal via-stone-dark to-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 60% 40%, rgba(193,154,107,0.4) 0%, transparent 50%);"></div>
    <div class="relative z-10 container mx-auto px-4 text-center">
      <div class="flex items-center justify-center mb-6 animate-fade-in">
        <span class="block w-12 h-px bg-gold-warm/50"></span>
        <span class="mx-4 text-gold-warm/70 text-sm font-accent tracking-[0.3em] uppercase">
          <span data-lang="el">Αρχείο</span><span data-lang="en">Archive</span>
        </span>
        <span class="block w-12 h-px bg-gold-warm/50"></span>
      </div>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-up">
        <span data-lang="el">Φωτογραφίες</span>
        <span data-lang="en">Photos</span>
      </h1>
      <p class="font-accent text-xl text-gold-light/80 max-w-2xl mx-auto animate-fade-up" style="animation-delay: 0.2s;">
        <span data-lang="el">Εκδηλώσεις χωρισμένες θεματολογικά και χρονολογικά</span>
        <span data-lang="en">Events organised by theme and by year</span>
      </p>
    </div>
  </section>

  <section class="py-20 bg-parchment">
    <div class="container mx-auto px-4 max-w-6xl">

      <!-- Filters -->
      <div class="animate-on-scroll space-y-6 mb-14">
        <div class="flex flex-wrap items-center justify-center gap-3">
          <span class="font-accent text-sm text-charcoal/75 uppercase tracking-wider mr-2">
            <span data-lang="el">Έτος:</span><span data-lang="en">Year:</span>
          </span>
          <button class="gallery-year-filter px-5 py-2 rounded-full font-accent text-sm tracking-wide transition-all duration-300 border border-stone-warm/30 hover:border-terracotta/50 hover:bg-terracotta/10 hover:text-terracotta data-[active=true]:bg-terracotta data-[active=true]:text-white data-[active=true]:border-terracotta" data-year="all" data-active="true">
            <span data-lang="el">Όλα</span><span data-lang="en">All</span>
          </button>
          {years.map((y) => (
            <button class="gallery-year-filter px-5 py-2 rounded-full font-accent text-sm tracking-wide transition-all duration-300 border border-stone-warm/30 hover:border-terracotta/50 hover:bg-terracotta/10 hover:text-terracotta data-[active=true]:bg-terracotta data-[active=true]:text-white data-[active=true]:border-terracotta" data-year={y} data-active="false">
              {y}
            </button>
          ))}
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <span class="font-accent text-sm text-charcoal/75 uppercase tracking-wider mr-2">
            <span data-lang="el">Θέμα:</span><span data-lang="en">Theme:</span>
          </span>
          {themes.map((t) => (
            <button class="gallery-theme-filter px-5 py-2 rounded-full font-accent text-sm tracking-wide transition-all duration-300 border border-stone-warm/30 hover:border-olive/50 hover:bg-olive/10 hover:text-olive-dark data-[active=true]:bg-olive data-[active=true]:text-white data-[active=true]:border-olive" data-theme={t.id} data-active={t.id === 'all' ? 'true' : 'false'}>
              <span data-lang="el">{t.el}</span>
              <span data-lang="en">{t.en}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Event Albums -->
      <div class="space-y-20" id="gallery-albums">
        {events.map((e) => {
          const photos = Array.from({ length: e.count }, (_, i) => `${e.folder}/${e.prefix}-${String(i + 1).padStart(2, '0')}.jpg`);
          return (
            <article class="album animate-on-scroll" data-year={e.year} data-theme={e.theme} id={e.slug}>
              <div class="flex flex-wrap items-baseline justify-between gap-4 mb-6 pb-4 border-b border-stone-warm/30">
                <div>
                  <h2 class="font-display text-2xl md:text-3xl font-bold text-charcoal">
                    <span data-lang="el">{e.title}</span>
                    <span data-lang="en">{e.titleEn}</span>
                  </h2>
                  <p class="font-accent text-sm text-terracotta mt-1 tracking-wider">{e.year}</p>
                </div>
                <span class="text-xs font-accent text-charcoal/70 bg-white px-3 py-1 rounded-full border border-stone-warm/30">
                  {e.count} <span data-lang="el">φωτογραφίες</span><span data-lang="en">photos</span>
                </span>
              </div>

              <p class="font-body text-charcoal/70 max-w-3xl mb-6 leading-relaxed">
                <span data-lang="el">{e.description}</span>
                <span data-lang="en">{e.descriptionEn}</span>
              </p>

              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                {photos.map((src, i) => (
                  <button
                    type="button"
                    class="lightbox-trigger group block aspect-square overflow-hidden rounded-sm bg-stone-warm/20 shadow-sm focus:outline-none focus:ring-2 focus:ring-terracotta/60"
                    data-album={e.slug}
                    data-index={i}
                    data-src={src}
                    data-caption-el={`${e.title} — ${e.year} (${i + 1}/${e.count})`}
                    data-caption-en={`${e.titleEn || e.title} — ${e.year} (${i + 1}/${e.count})`}
                  >
                    <img
                      src={src}
                      alt={e.titleEn ? `${e.title} — ${e.titleEn} (${i + 1})` : `${e.title} (${i + 1})`}
                      loading="lazy"
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    />
                  </button>
                ))}
              </div>
            </article>
          );
        })}
      </div>

      <div id="gallery-empty" class="hidden text-center py-16">
        <p class="font-body text-charcoal/75 text-lg">
          <span data-lang="el">Δεν υπάρχουν φωτογραφίες για αυτά τα φίλτρα.</span>
          <span data-lang="en">No photos match the selected filters.</span>
        </p>
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="lightbox-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Φωτογραφία / Photo viewer"
  >
    <button
      id="lightbox-close"
      type="button"
      class="absolute top-4 right-4 md:top-6 md:right-6 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition"
      aria-label="Κλείσιμο / Close"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <button
      id="lightbox-prev"
      type="button"
      class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 w-11 h-11 md:w-14 md:h-14 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition"
      aria-label="Προηγούμενη / Previous"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>

    <button
      id="lightbox-next"
      type="button"
      class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 w-11 h-11 md:w-14 md:h-14 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition"
      aria-label="Επόμενη / Next"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <figure class="max-w-6xl max-h-[85vh] w-full flex flex-col items-center justify-center gap-4 px-4">
      <img id="lightbox-img" src="" alt="" class="max-h-[75vh] w-auto rounded-sm shadow-2xl" />
      <figcaption id="lightbox-caption" class="font-accent text-sm md:text-base text-white/90 text-center tracking-wide">
        <span data-lang="el"></span>
        <span data-lang="en"></span>
      </figcaption>
    </figure>
  </div>

  <script>
    const yearBtns = document.querySelectorAll('.gallery-year-filter');
    const themeBtns = document.querySelectorAll('.gallery-theme-filter');
    const albums = document.querySelectorAll<HTMLElement>('.album');
    const emptyMsg = document.getElementById('gallery-empty');

    let activeYear: string = 'all';
    let activeTheme: string = 'all';

    function apply() {
      let visible = 0;
      albums.forEach((a) => {
        const y = a.dataset.year || '';
        const t = a.dataset.theme || '';
        const ok = (activeYear === 'all' || activeYear === y) && (activeTheme === 'all' || activeTheme === t);
        a.style.display = ok ? '' : 'none';
        if (ok) visible++;
      });
      if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
    }

    yearBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        yearBtns.forEach((b) => b.setAttribute('data-active', 'false'));
        btn.setAttribute('data-active', 'true');
        activeYear = btn.getAttribute('data-year') || 'all';
        apply();
      });
    });

    themeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        themeBtns.forEach((b) => b.setAttribute('data-active', 'false'));
        btn.setAttribute('data-active', 'true');
        activeTheme = btn.getAttribute('data-theme') || 'all';
        apply();
      });
    });

    // Lightbox
    const lightbox = document.getElementById('lightbox') as HTMLElement | null;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lbCloseBtn = document.getElementById('lightbox-close');
    const lbPrevBtn = document.getElementById('lightbox-prev');
    const lbNextBtn = document.getElementById('lightbox-next');
    const lbCaption = document.getElementById('lightbox-caption');

    let currentGroup: HTMLElement[] = [];
    let currentIdx = 0;

    function openLightbox(trigger: HTMLElement) {
      const album = trigger.getAttribute('data-album');
      currentGroup = Array.from(
        document.querySelectorAll<HTMLElement>(`.lightbox-trigger[data-album="${album}"]`)
      );
      currentIdx = currentGroup.indexOf(trigger);
      showCurrent();
      lightbox?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function showCurrent() {
      const t = currentGroup[currentIdx];
      if (!t || !lbImg || !lbCaption) return;
      const src = t.getAttribute('data-src') || '';
      const capEl = t.getAttribute('data-caption-el') || '';
      const capEn = t.getAttribute('data-caption-en') || '';
      lbImg.src = src;
      lbImg.alt = capEl;
      const elSpan = lbCaption.querySelector<HTMLElement>('[data-lang="el"]');
      const enSpan = lbCaption.querySelector<HTMLElement>('[data-lang="en"]');
      if (elSpan) elSpan.textContent = capEl;
      if (enSpan) enSpan.textContent = capEn;
    }

    function closeLightbox() {
      lightbox?.classList.remove('active');
      document.body.style.overflow = '';
      if (lbImg) lbImg.src = '';
    }

    function next(delta: number) {
      if (!currentGroup.length) return;
      currentIdx = (currentIdx + delta + currentGroup.length) % currentGroup.length;
      showCurrent();
    }

    document.querySelectorAll<HTMLElement>('.lightbox-trigger').forEach((btn) => {
      btn.addEventListener('click', () => openLightbox(btn));
    });
    lbCloseBtn?.addEventListener('click', closeLightbox);
    lbPrevBtn?.addEventListener('click', () => next(-1));
    lbNextBtn?.addEventListener('click', () => next(1));
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowRight') next(1);
      else if (e.key === 'ArrowLeft') next(-1);
    });
  </script>

</BaseLayout>
