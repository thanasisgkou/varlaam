---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date.toLocaleDateString('el-GR', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedEndDate = entry.data.endDate
  ? entry.data.endDate.toLocaleDateString('el-GR', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://varlaam.netlify.app';
const eventUrl = `${site}/events/${entry.slug}/`;
const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: entry.data.title,
  description: entry.data.excerpt,
  startDate: entry.data.date.toISOString(),
  endDate: (entry.data.endDate ?? new Date(entry.data.date.getTime() + 2 * 60 * 60 * 1000)).toISOString(),
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  url: eventUrl,
  image: entry.data.image ? new URL(entry.data.image, site).toString() : `${site}/images/attractions/xirovouni/xirovouni-01.jpg`,
  location: {
    '@type': 'Place',
    name: entry.data.location,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Βαρλαάμ',
      addressRegion: 'Ιωάννινα',
      postalCode: '455 00',
      addressCountry: 'GR',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Σύλλογος Βαρλαάμ Ιωαννίνων',
    url: site,
  },
};
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt} jsonLd={eventJsonLd}>

  <div class="pt-20"></div>
  <Breadcrumbs items={[
    { el: 'Εκδηλώσεις', en: 'Events', href: '/events/' },
    { el: entry.data.title, en: entry.data.title },
  ]} />

  <!-- Hero Banner -->
  <section class="relative py-28 md:py-36 bg-gradient-to-br from-charcoal via-stone-dark to-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 50% 50%, rgba(183,65,14,0.3) 0%, transparent 50%);"></div>
    <div class="relative z-10 container mx-auto px-4 text-center max-w-4xl">
      <div class="flex items-center justify-center mb-6 animate-fade-in">
        <span class="block w-12 h-px bg-gold-warm/50"></span>
        <span class="mx-4 text-gold-warm/70 text-sm font-accent tracking-[0.3em] uppercase">Εκδήλωση</span>
        <span class="block w-12 h-px bg-gold-warm/50"></span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 animate-fade-up">
        {entry.data.title}
      </h1>

      <!-- Event Meta -->
      <div class="flex flex-wrap items-center justify-center gap-6 text-gold-light/70 font-accent animate-fade-up" style="animation-delay: 0.2s;">
        <span class="inline-flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
        </span>
        {formattedEndDate && entry.data.endDate && (
          <span class="inline-flex items-center gap-2">
            <span class="text-gold-warm/40">&mdash;</span>
            <time datetime={entry.data.endDate.toISOString()}>{formattedEndDate}</time>
          </span>
        )}
        <span class="inline-flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          {entry.data.location}
        </span>
      </div>
    </div>
  </section>

  <!-- Event Content -->
  <section class="py-20 bg-parchment">
    <div class="container mx-auto px-4 max-w-3xl">
      <!-- Back Link + ICS -->
      <div class="flex flex-wrap items-center justify-between gap-4 mb-12">
        <a href="/events" class="inline-flex items-center text-olive-dark hover:text-terracotta transition-colors font-accent group">
          <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span data-lang="el">Πίσω στις Εκδηλώσεις</span>
          <span data-lang="en">Back to Events</span>
        </a>
        <a
          href={`/events/${entry.slug}.ics`}
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-olive/40 text-olive-dark hover:bg-olive hover:text-white transition-colors font-accent text-sm"
          download
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span data-lang="el">Προσθήκη στο ημερολόγιο</span>
          <span data-lang="en">Add to calendar</span>
        </a>
      </div>

      <!-- Event Details Card -->
      <div class="animate-on-scroll bg-white rounded-xl shadow-sm border border-stone-warm/10 p-4 md:p-6 mb-10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="text-center p-4 rounded-lg bg-parchment/50">
            <svg class="w-6 h-6 mx-auto text-terracotta/60 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <div class="font-display text-sm text-charcoal font-semibold">Ημερομηνία</div>
            <div class="font-body text-sm text-charcoal/70 mt-1">{formattedDate}</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-parchment/50">
            <svg class="w-6 h-6 mx-auto text-terracotta/60 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div class="font-display text-sm text-charcoal font-semibold">Τοποθεσία</div>
            <div class="font-body text-sm text-charcoal/70 mt-1">{entry.data.location}</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-parchment/50">
            <svg class="w-6 h-6 mx-auto text-terracotta/60 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div class="font-display text-sm text-charcoal font-semibold">Κατάσταση</div>
            <div class="font-body text-sm text-charcoal/70 mt-1">
              {entry.data.date >= new Date() ? 'Επερχόμενη' : 'Ολοκληρωμένη'}
            </div>
          </div>
        </div>
      </div>

      <!-- Article Body -->
      <article class="animate-on-scroll bg-white rounded-xl shadow-sm border border-stone-warm/10 p-8 md:p-12">
        <div class="prose prose-lg max-w-none
          prose-headings:font-display prose-headings:text-charcoal
          prose-p:font-body prose-p:text-charcoal/80 prose-p:leading-relaxed
          prose-a:text-olive-dark prose-a:underline-offset-4 hover:prose-a:text-terracotta
          prose-strong:text-charcoal prose-strong:font-semibold
          prose-blockquote:border-terracotta/40 prose-blockquote:bg-parchment/50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
          prose-img:rounded-lg prose-img:shadow-md">
          <Content />
        </div>
      </article>

      <!-- Navigation -->
      <div class="mt-12 pt-8 border-t border-stone-warm/20 text-center">
        <a href="/events" class="btn-secondary">
          &larr; Όλες οι Εκδηλώσεις
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
