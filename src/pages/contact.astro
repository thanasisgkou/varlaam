---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Επικοινωνία" description="Επικοινωνήστε μαζί μας - Σύλλογος Βαρλαάμ Ιωαννίνων">

  <!-- Hero Banner -->
  <section class="relative py-28 md:py-36 bg-gradient-to-br from-charcoal via-stone-dark to-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 40% 60%, rgba(193,154,107,0.4) 0%, transparent 50%);"></div>
    <div class="relative z-10 container mx-auto px-4 text-center">
      <div class="flex items-center justify-center mb-6 animate-fade-in">
        <span class="block w-12 h-px bg-gold-warm/50"></span>
        <span class="mx-4 text-gold-warm/70 text-sm font-accent tracking-[0.3em] uppercase">Βαρλαάμ</span>
        <span class="block w-12 h-px bg-gold-warm/50"></span>
      </div>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-up">
        <span data-lang="el">Επικοινωνία</span>
        <span data-lang="en">Contact</span>
      </h1>
      <p class="font-accent text-xl text-gold-light/80 max-w-2xl mx-auto animate-fade-up" style="animation-delay: 0.2s;">
        <span data-lang="el">Θα χαρούμε να ακούσουμε τα νέα σας</span>
        <span data-lang="en">We'd love to hear from you</span>
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 bg-parchment">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Contact Form -->
        <div class="animate-on-scroll animate-slide-in-left">
          <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-2">
            <span data-lang="el">Στείλτε μας μήνυμα</span>
            <span data-lang="en">Send us a message</span>
          </h2>
          <p class="font-body text-charcoal/60 mb-8">
            <span data-lang="el">Συμπληρώστε τη φόρμα και θα σας απαντήσουμε το συντομότερο δυνατό.</span>
            <span data-lang="en">Fill in the form and we'll get back to you as soon as possible.</span>
          </p>

          <form name="contact" method="POST" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="contact-name" class="block font-accent text-sm text-charcoal/70 mb-2">Ονοματεπώνυμο</label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                  placeholder="Το όνομά σας"
                />
              </div>
              <div>
                <label for="contact-email" class="block font-accent text-sm text-charcoal/70 mb-2">Email</label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div>
              <label for="contact-subject" class="block font-accent text-sm text-charcoal/70 mb-2">Θέμα</label>
              <input
                type="text"
                id="contact-subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                placeholder="Θέμα μηνύματος"
              />
            </div>

            <div>
              <label for="contact-message" class="block font-accent text-sm text-charcoal/70 mb-2">Μήνυμα</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="6"
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors resize-y"
                placeholder="Γράψτε το μήνυμά σας..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full sm:w-auto justify-center px-10 py-3.5">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Αποστολή
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="animate-on-scroll animate-slide-in-right">
          <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-2">
            <span data-lang="el">Στοιχεία Επικοινωνίας</span>
            <span data-lang="en">Contact Details</span>
          </h2>
          <p class="font-body text-charcoal/60 mb-8">
            <span data-lang="el">Βρείτε μας και με τους παρακάτω τρόπους.</span>
            <span data-lang="en">You can also reach us through the following channels.</span>
          </p>

          <div class="space-y-6 mb-10">
            <!-- Address -->
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-olive/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display text-base text-charcoal mb-1">
                  <span data-lang="el">Διεύθυνση</span>
                  <span data-lang="en">Address</span>
                </h3>
                <p class="font-body text-charcoal/70 text-sm leading-relaxed" data-lang="el">
                  Βαρλαάμ<br>
                  Δήμος Δωδώνης, Νομός Ιωαννίνων<br>
                  Ήπειρος, Ελλάδα
                </p>
                <p class="font-body text-charcoal/70 text-sm leading-relaxed" data-lang="en">
                  Varlaam<br>
                  Municipality of Dodoni, Ioannina Prefecture<br>
                  Epirus, Greece
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-olive/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display text-base text-charcoal mb-1">Email</h3>
                <a href="mailto:syllogosvarlaam@gmail.com" class="font-body text-olive-dark hover:text-terracotta transition-colors text-sm break-all">
                  syllogosvarlaam@gmail.com
                </a>
              </div>
            </div>

            <!-- Social Media -->
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-olive/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a3 3 0 015.356-1.857M17 10.5a3.5 3.5 0 11-7 0 3.5 3.5 0 017 0zM7 10.5a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display text-base text-charcoal mb-1">
                  <span data-lang="el">Μέσα κοινωνικής δικτύωσης</span>
                  <span data-lang="en">Social Media</span>
                </h3>
                <div class="flex flex-col gap-1 text-sm">
                  <a href="https://www.facebook.com/search/top?q=%CF%80%CE%BF%CE%BB%CE%B9%CF%84%CE%B9%CF%83%CF%84%CE%B9%CE%BA%CF%8C%CF%82%20%CE%BC%CE%BF%CF%81%CF%86%CF%89%CF%84%CE%B9%CE%BA%CF%8C%CF%82%20%CF%83%CF%8D%CE%BB%CE%BB%CE%BF%CE%B3%CE%BF%CF%82%20%CE%B2%CE%B1%CF%81%CE%BB%CE%B1%CE%AC%CE%BC%20%CE%B9%CF%89%CE%B1%CE%BD%CE%BD%CE%AF%CE%BD%CF%89%CE%BD" target="_blank" rel="noopener" class="font-body text-olive-dark hover:text-terracotta transition-colors">
                    Facebook — Πολιτιστικός Σύλλογος Βαρλαάμ Ιωαννίνων
                  </a>
                  <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="font-body text-olive-dark hover:text-terracotta transition-colors">
                    Instagram — Πολιτιστικός Σύλλογος Βαρλαάμ Ιωαννίνων
                  </a>
                </div>
              </div>
            </div>

            <!-- Bank Account -->
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-olive/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M3 10l9-6 9 6M5 10v10h14V10M9 20v-6h6v6"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display text-base text-charcoal mb-1">
                  <span data-lang="el">Τραπεζικός Λογαριασμός Συλλόγου</span>
                  <span data-lang="en">Association Bank Account</span>
                </h3>
                <p class="font-body text-charcoal/70 text-sm">
                  <span data-lang="el">Εθνική Τράπεζα της Ελλάδος</span>
                  <span data-lang="en">National Bank of Greece</span>
                </p>
                <p class="font-mono text-charcoal text-sm mt-1 tracking-wider select-all">GR54 0110 3590 0000 3590 1865 978</p>
                <p class="font-body text-charcoal/50 text-xs mt-1">
                  <span data-lang="el">Για δωρεές και οικονομική στήριξη των δράσεων του Συλλόγου</span>
                  <span data-lang="en">For donations and financial support of the Association's activities</span>
                </p>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="mt-8 rounded-xl overflow-hidden shadow-sm border border-stone-warm/10">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1287!2d20.8887209!3d39.4201989!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x135bf75da7e49ded%3A0xa1fe3b9befbd1a88!2zzpLOsc-BzrvOsc6szrzOuiA0NTUgMDAsIM6VzrvOu86szrTOsQ!5e0!3m2!1sel!2sgr"
              width="100%"
              height="250"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Χάρτης Βαρλαάμ Ιωαννίνων"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Useful Links Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="animate-on-scroll text-center mb-12">
        <h2 class="section-title">Χρήσιμοι Σύνδεσμοι</h2>
        <div class="divider mx-auto mt-6"></div>
      </div>

      <div class="animate-on-scroll grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="https://www.ioannina.gr" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 rounded-lg border border-stone-warm/15 hover:border-olive/30 hover:bg-parchment/50 transition-all group">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center group-hover:bg-olive/20 transition-colors">
            <svg class="w-5 h-5 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
          </div>
          <div>
            <span class="font-display text-sm text-charcoal group-hover:text-olive-dark transition-colors">Δήμος Ιωαννιτών</span>
            <span class="block font-body text-xs text-charcoal/40">ioannina.gr</span>
          </div>
        </a>

        <a href="https://www.php.gov.gr" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 rounded-lg border border-stone-warm/15 hover:border-olive/30 hover:bg-parchment/50 transition-all group">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center group-hover:bg-olive/20 transition-colors">
            <svg class="w-5 h-5 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <span class="font-display text-sm text-charcoal group-hover:text-olive-dark transition-colors">Περιφέρεια Ηπείρου</span>
            <span class="block font-body text-xs text-charcoal/40">php.gov.gr</span>
          </div>
        </a>

        <a href="https://www.visitgreece.gr/destinations/epirus/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 rounded-lg border border-stone-warm/15 hover:border-olive/30 hover:bg-parchment/50 transition-all group">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center group-hover:bg-olive/20 transition-colors">
            <svg class="w-5 h-5 text-olive-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <span class="font-display text-sm text-charcoal group-hover:text-olive-dark transition-colors">Τουρισμός Ηπείρου</span>
            <span class="block font-body text-xs text-charcoal/40">visitgreece.gr</span>
          </div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
