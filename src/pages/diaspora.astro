---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const stories = await getCollection('diaspora-stories');
const bulletins = (await getCollection('diaspora-bulletin'))
  .filter((b) => b.data.approved)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Απόδημοι" description="Η κοινότητα των αποδήμων Βαρλαμιωτών - Ιστορίες, ανακοινώσεις και επικοινωνία">

  <!-- Hero Banner -->
  <section class="relative py-28 md:py-36 bg-gradient-to-br from-charcoal via-stone-dark to-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 60%, rgba(193,154,107,0.4) 0%, transparent 50%), radial-gradient(circle at 70% 40%, rgba(183,65,14,0.2) 0%, transparent 50%);"></div>
    <div class="relative z-10 container mx-auto px-4 text-center">
      <div class="flex items-center justify-center mb-6 animate-fade-in">
        <span class="block w-12 h-px bg-gold-warm/50"></span>
        <span class="mx-4 text-gold-warm/70 text-sm font-accent tracking-[0.3em] uppercase">
          <span data-lang="el">Κοινότητα</span><span data-lang="en">Community</span>
        </span>
        <span class="block w-12 h-px bg-gold-warm/50"></span>
      </div>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-up">
        <span data-lang="el">Απόδημοι Βαρλαάμ</span>
        <span data-lang="en">The Varlaam Diaspora</span>
      </h1>
      <p class="font-accent text-xl text-gold-light/80 max-w-2xl mx-auto animate-fade-up" style="animation-delay: 0.2s;">
        <span data-lang="el">Όπου κι αν βρίσκεστε, η καρδιά σας χτυπά στο Βαρλαάμ</span>
        <span data-lang="en">Wherever you are, your heart beats for Varlaam</span>
      </p>
    </div>
  </section>

  <!-- Welcome Message -->
  <section class="py-20 bg-parchment">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="animate-on-scroll text-center">
        <div class="bg-white rounded-xl shadow-sm border border-stone-warm/10 p-8 md:p-12 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-terracotta via-gold-warm to-olive"></div>
          <svg class="w-10 h-10 mx-auto text-terracotta/40 mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-4">Αγαπητοί Απόδημοι</h2>
          <p class="font-body text-lg text-charcoal/70 leading-relaxed">
            Αυτή η σελίδα είναι αφιερωμένη σε όλους εσάς που μεγαλώσατε στο Βαρλαάμ ή
            έχετε ρίζες από εδώ. Μοιραστείτε τις ιστορίες σας, μείνετε ενήμεροι για τα
            νέα του χωριού και κρατήστε ζωντανούς τους δεσμούς με τον τόπο μας. Το Βαρλαάμ
            θα είναι πάντα το σπίτι σας.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bulletin Board Section -->
  <section class="py-24 bg-white" id="pinakes">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="animate-on-scroll text-center mb-16">
        <h2 class="section-title">Πίνακας Ανακοινώσεων</h2>
        <p class="section-subtitle">Στείλτε τη δική σας ανακοίνωση ή μήνυμα</p>
        <div class="divider mx-auto mt-6"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Existing Bulletins -->
        <div class="animate-on-scroll animate-slide-in-left">
          <h3 class="font-display text-xl text-charcoal mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-terracotta/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Τελευταίες Ανακοινώσεις
          </h3>

          {bulletins.length > 0 ? (
            <div class="space-y-4">
              {bulletins.map((bulletin) => (
                <div class="p-5 rounded-lg border border-stone-warm/15 bg-parchment/30 hover:border-stone-warm/30 transition-colors">
                  <h4 class="font-display text-base text-charcoal mb-1">{bulletin.data.title}</h4>
                  <div class="flex items-center gap-3 text-sm text-charcoal/70 font-body">
                    <span>{bulletin.data.author}</span>
                    <span class="w-1 h-1 rounded-full bg-stone-warm/30"></span>
                    <time datetime={bulletin.data.date.toISOString()}>
                      {bulletin.data.date.toLocaleDateString('el-GR', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-12 border-2 border-dashed border-stone-warm/20 rounded-xl">
              <svg class="w-12 h-12 mx-auto text-stone-warm/30 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              <p class="font-body text-charcoal/70">Δεν υπάρχουν ανακοινώσεις ακόμα.</p>
              <p class="font-body text-charcoal/70 text-sm mt-1">Γίνετε ο πρώτος!</p>
            </div>
          )}
        </div>

        <!-- Submission Form -->
        <div class="animate-on-scroll animate-slide-in-right">
          <h3 class="font-display text-xl text-charcoal mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-terracotta/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Νέα Ανακοίνωση
          </h3>

          <form name="bulletin" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="bulletin" />

            <div>
              <label for="bulletin-name" class="block font-accent text-sm text-charcoal/70 mb-2">Ονοματεπώνυμο</label>
              <input
                type="text"
                id="bulletin-name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                placeholder="Το όνομά σας"
              />
            </div>

            <div>
              <label for="bulletin-email" class="block font-accent text-sm text-charcoal/70 mb-2">Email</label>
              <input
                type="email"
                id="bulletin-email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="bulletin-title" class="block font-accent text-sm text-charcoal/70 mb-2">Τίτλος</label>
              <input
                type="text"
                id="bulletin-title"
                name="title"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors"
                placeholder="Τίτλος ανακοίνωσης"
              />
            </div>

            <div>
              <label for="bulletin-message" class="block font-accent text-sm text-charcoal/70 mb-2">Μήνυμα</label>
              <textarea
                id="bulletin-message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-stone-warm/30 bg-white font-body text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-olive/30 focus:border-olive transition-colors resize-y"
                placeholder="Γράψτε το μήνυμά σας..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center">
              Αποστολή Ανακοίνωσης
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Diaspora Stories Section -->
  <section class="py-24 bg-parchment" id="stories">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="animate-on-scroll text-center mb-16">
        <h2 class="section-title">Ιστορίες Αποδήμων</h2>
        <p class="section-subtitle">Ζωές που ξεκίνησαν από το Βαρλαάμ</p>
        <div class="divider mx-auto mt-6"></div>
      </div>

      {stories.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {stories.map((story, index) => (
            <div class="animate-on-scroll card group" style={`animation-delay: ${index * 0.1}s;`}>
              <div class="p-8">
                <!-- Quote Icon -->
                <svg class="w-8 h-8 text-terracotta/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
                </svg>

                <p class="font-body text-charcoal/70 leading-relaxed mb-6 italic line-clamp-4">
                  "{story.data.excerpt}"
                </p>

                <div class="flex items-center gap-4 pt-4 border-t border-stone-warm/15">
                  <!-- Avatar Placeholder -->
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-stone-warm/30 to-olive/20 flex items-center justify-center flex-shrink-0">
                    <span class="font-display text-lg text-charcoal/70">{story.data.name.charAt(0)}</span>
                  </div>
                  <div>
                    <div class="font-display text-base text-charcoal">{story.data.name}</div>
                    <div class="font-body text-sm text-charcoal/70 flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      </svg>
                      {story.data.location}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 animate-on-scroll">
          <svg class="w-16 h-16 mx-auto text-stone-warm/30 mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
          </svg>
          <h3 class="font-display text-2xl text-charcoal/75 mb-2">
            <span data-lang="el">Δεν υπάρχουν ιστορίες ακόμα</span>
            <span data-lang="en">No stories yet</span>
          </h3>
          <p class="font-body text-charcoal/70">
            <span data-lang="el">Γίνετε ο πρώτος — μοιραστείτε τη δική σας παρακάτω.</span>
            <span data-lang="en">Be the first — share yours below.</span>
          </p>
        </div>
      )}

      <!-- Story submission form (G·02) -->
      <div class="mt-16 animate-on-scroll" id="share-your-story">
        <div class="bg-white rounded-xl shadow-sm border border-stone-warm/15 p-8 md:p-10">
          <div class="text-center mb-8">
            <h3 class="font-display text-2xl md:text-3xl font-bold text-charcoal mb-2">
              <span data-lang="el">Μοιραστείτε την ιστορία σας</span>
              <span data-lang="en">Share your story</span>
            </h3>
            <p class="font-body text-charcoal/75 max-w-2xl mx-auto">
              <span data-lang="el">Μια ανάμνηση, μια οικογενειακή ιστορία, μια στιγμή από το Βαρλαάμ. Ο Σύλλογος ελέγχει τις υποβολές πριν τη δημοσίευση.</span>
              <span data-lang="en">A memory, a family story, a moment from Varlaam. The Association reviews every submission before publishing.</span>
            </p>
          </div>

          <form
            name="diaspora-story"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you/"
            class="space-y-5 max-w-2xl mx-auto"
          >
            <input type="hidden" name="form-name" value="diaspora-story" />
            <p class="hidden"><label>Αφήστε κενό / Leave empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <label class="block">
                <span class="font-accent text-xs uppercase tracking-wider text-charcoal/75">
                  <span data-lang="el">Ονοματεπώνυμο</span><span data-lang="en">Name</span> *
                </span>
                <input type="text" name="name" required maxlength="120" class="mt-1 w-full px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-terracotta/40 focus:border-terracotta/40 transition-colors" />
              </label>
              <label class="block">
                <span class="font-accent text-xs uppercase tracking-wider text-charcoal/75">
                  <span data-lang="el">Τοποθεσία (πόλη)</span><span data-lang="en">Location (city)</span>
                </span>
                <input type="text" name="location" maxlength="120" placeholder="Αθήνα · Μελβούρνη · Στοκχόλμη…" class="mt-1 w-full px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-terracotta/40 focus:border-terracotta/40 transition-colors" />
              </label>
            </div>

            <label class="block">
              <span class="font-accent text-xs uppercase tracking-wider text-charcoal/75">
                <span data-lang="el">Email (προαιρετικό)</span><span data-lang="en">Email (optional)</span>
              </span>
              <input type="email" name="email" maxlength="200" class="mt-1 w-full px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-terracotta/40 focus:border-terracotta/40 transition-colors" />
              <span class="text-xs text-charcoal/70 mt-1 block">
                <span data-lang="el">Για να σας ενημερώσουμε όταν δημοσιευτεί.</span>
                <span data-lang="en">So we can let you know when it's published.</span>
              </span>
            </label>

            <label class="block">
              <span class="font-accent text-xs uppercase tracking-wider text-charcoal/75">
                <span data-lang="el">Τίτλος</span><span data-lang="en">Title</span> *
              </span>
              <input type="text" name="title" required maxlength="200" class="mt-1 w-full px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-terracotta/40 focus:border-terracotta/40 transition-colors" />
            </label>

            <label class="block">
              <span class="font-accent text-xs uppercase tracking-wider text-charcoal/75">
                <span data-lang="el">Η ιστορία σας</span><span data-lang="en">Your story</span> *
              </span>
              <textarea name="story" required rows="8" minlength="80" maxlength="5000" class="mt-1 w-full px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-terracotta/40 focus:border-terracotta/40 transition-colors resize-y" placeholder="Ξεκινήστε από την παλιότερη ανάμνηση που σας έρχεται στο μυαλό…"></textarea>
            </label>

            <label class="flex items-start gap-3 text-sm text-charcoal/75">
              <input type="checkbox" name="consent" required class="mt-1 w-4 h-4 accent-terracotta" />
              <span>
                <span data-lang="el">Δίνω τη συγκατάθεσή μου να δημοσιευτεί η ιστορία στον ιστότοπο του Συλλόγου (μετά από έλεγχο) και να αναφέρεται το όνομα και η τοποθεσία.</span>
                <span data-lang="en">I consent to the Association publishing this story on the website (after review) and displaying my name and location.</span>
              </span>
            </label>

            <div class="text-center pt-2">
              <button type="submit" class="btn-primary">
                <span data-lang="el">Υποβολή ιστορίας</span>
                <span data-lang="en">Submit story</span>
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Diaspora map opt-in (G·01) -->
      <div class="mt-10 animate-on-scroll" id="diaspora-map-optin">
        <div class="bg-parchment/70 rounded-xl border border-stone-warm/20 p-8 md:p-10">
          <div class="text-center mb-6">
            <h3 class="font-display text-xl md:text-2xl font-bold text-charcoal mb-2">
              <span data-lang="el">Μπείτε στον χάρτη των αποδήμων</span>
              <span data-lang="en">Pin yourself on the diaspora map</span>
            </h3>
            <p class="font-body text-charcoal/75 max-w-2xl mx-auto text-sm">
              <span data-lang="el">Μόνο πόλη και χώρα — καμία διεύθυνση, κανένα προσωπικό δεδομένο. Βλέπουμε όλοι μαζί πού έχει απλωθεί το χωριό.</span>
              <span data-lang="en">City and country only — no address, no personal data. Together we can see how far the village has spread.</span>
            </p>
          </div>

          <form
            name="diaspora-map"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you/"
            class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto"
          >
            <input type="hidden" name="form-name" value="diaspora-map" />
            <p class="hidden"><label>Αφήστε κενό: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

            <input type="text" name="display-name" maxlength="80" placeholder="Όνομα (προαιρετικό)" class="px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-olive/40" />
            <input type="text" name="city" required maxlength="80" placeholder="Πόλη *" class="px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-olive/40" />
            <input type="text" name="country" required maxlength="80" placeholder="Χώρα *" class="px-4 py-2.5 rounded-md border border-stone-warm/40 font-body focus:outline-none focus:ring-2 focus:ring-olive/40" />
            <div class="sm:col-span-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
              <label class="flex items-start gap-2 text-xs text-charcoal/75">
                <input type="checkbox" name="map-consent" required class="mt-0.5 w-4 h-4 accent-olive" />
                <span>
                  <span data-lang="el">Συναινώ στην εμφάνιση της πόλης/χώρας μου στον χάρτη.</span>
                  <span data-lang="en">I consent to displaying my city/country on the map.</span>
                </span>
              </label>
              <button type="submit" class="btn-secondary">
                <span data-lang="el">Προσθήκη στον χάρτη</span>
                <span data-lang="en">Pin me</span>
              </button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-24 bg-gradient-to-br from-olive-dark to-charcoal relative overflow-hidden" id="newsletter">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="container mx-auto px-4 max-w-2xl relative z-10">
      <div class="animate-on-scroll text-center">
        <svg class="w-12 h-12 mx-auto text-gold-warm/40 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>

        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          Ενημερωτικό Δελτίο
        </h2>
        <p class="font-body text-lg text-stone-warm/80 mb-10 leading-relaxed">
          Εγγραφείτε στο ενημερωτικό μας δελτίο για να λαμβάνετε τα τελευταία νέα
          και ανακοινώσεις από το Βαρλαάμ απευθείας στο email σας.
        </p>

        <form name="newsletter" method="POST" data-netlify="true" class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
          <input type="hidden" name="form-name" value="newsletter" />
          <input
            type="email"
            name="email"
            required
            placeholder="Το email σας"
            class="flex-1 px-5 py-3.5 rounded-lg bg-white/10 border border-white/20 font-body text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-gold-warm/40 focus:border-gold-warm/40 transition-colors backdrop-blur-sm"
          />
          <button type="submit" class="btn-primary flex-shrink-0 whitespace-nowrap">
            Εγγραφή
          </button>
        </form>

        <p class="font-body text-xs text-stone-warm/50 mt-4">
          Δεν θα μοιραστούμε ποτέ το email σας. Μπορείτε να διαγραφείτε ανά πάσα στιγμή.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
